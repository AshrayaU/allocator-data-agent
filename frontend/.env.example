# Copy to .env. Never commit .env.

VITE_API_URL=http://localhost:8001/api
SERVER_TYPE=dev

APP_BASE=frontend

# GITHUB_TOKEN — PRODUCTION ONLY (leave blank locally).
# Needed only because this app depends on @allocator/design-system, which npm
# installs as a git dependency from a PRIVATE GitHub repo. On Heroku the build
# clones that repo and needs credentials; the heroku-prebuild script uses this
# token to authenticate. Locally you don't need it — your own GitHub access
# (SSH / credential helper) already lets npm clone the repo.
# The token is a read-only PAT scoped to ONLY allctr/allocator-design-system.
# The CTO sets it as a Heroku config var at deploy time — never commit a real token.
GITHUB_TOKEN=
