{
  "name": "allocator-qa-frontend",
  "private": true,
  "version": "0.0.1",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "heroku-prebuild": "if [ -n \"$GITHUB_TOKEN\" ]; then git config --global url.\"https://$GITHUB_TOKEN@github.com/\".insteadOf \"https://github.com/\"; fi",
    "heroku-postbuild": "npm run build"
  },
  "dependencies": {
    "@allocator/design-system": "git+https://github.com/allctr/allocator-design-system.git#v1.0.0",
    "@tanstack/react-query": "^5.0.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  },
  "allowScripts": {
    "esbuild@0.21.5": true
  }
}
