#!/usr/bin/env bash
set -euo pipefail

# ---------------------------------------------------------------------------
# backend/bin/db
#
# Database management.
#
# Usage:
#   bin/db migrate    # create DB if absent (dev only), alembic upgrade head
#   bin/db seed       # load reference/seed data (idempotent)
#   bin/db localize   # dev only: drop local DB and restore a Heroku dump
# ---------------------------------------------------------------------------

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BACKEND_DIR="$(dirname "$SCRIPT_DIR")"

# Source .env on dev.
if [[ -f "$BACKEND_DIR/.env" ]]; then
  set -a
  # shellcheck disable=SC1091
  source "$BACKEND_DIR/.env"
  set +a
fi

# SERVER_TYPE is required.
if [[ -z "${SERVER_TYPE:-}" ]]; then
  echo "ERROR: SERVER_TYPE is not set. Set it to 'dev' or 'production' in .env." >&2
  exit 1
fi

cd "$BACKEND_DIR"

_python() {
  if [[ -x "$BACKEND_DIR/.venv/bin/python" ]]; then
    "$BACKEND_DIR/.venv/bin/python" "$@"
  elif [[ -x "$BACKEND_DIR/.venv/Scripts/python.exe" ]]; then
    "$BACKEND_DIR/.venv/Scripts/python.exe" "$@"
  else
    python3 "$@"
  fi
}

_alembic() {
  if [[ -x "$BACKEND_DIR/.venv/bin/alembic" ]]; then
    "$BACKEND_DIR/.venv/bin/alembic" "$@"
  elif [[ -x "$BACKEND_DIR/.venv/Scripts/alembic.exe" ]]; then
    "$BACKEND_DIR/.venv/Scripts/alembic.exe" "$@"
  else
    alembic "$@"
  fi
}

COMMAND="${1:-}"

case "$COMMAND" in
  migrate)
    if [[ "$SERVER_TYPE" == "dev" ]]; then
      # Auto-create local database if it doesn't exist yet.
      # DATABASE_URL format: postgresql+psycopg://localhost/allocator-qa_dev
      DB_NAME="${DATABASE_URL##*/}"
      # Strip query string if present
      DB_NAME="${DB_NAME%%\?*}"
      if [[ -n "$DB_NAME" ]]; then
        if ! psql -lqt 2>/dev/null | cut -d \| -f 1 | grep -qw "$DB_NAME"; then
          echo "==> [db] Creating local database: $DB_NAME"
          createdb "$DB_NAME"
        fi
      fi
    fi
    echo "==> [db] Running alembic upgrade head"
    _alembic upgrade head
    echo "==> [db] Migrations complete."
    ;;

  seed)
    echo "==> [db] Running seed"
    _python db/seed.py
    echo "==> [db] Seed complete."
    ;;

  localize)
    if [[ "$SERVER_TYPE" != "dev" ]]; then
      echo "ERROR: bin/db localize can only be run with SERVER_TYPE=dev." >&2
      exit 1
    fi

    echo "WARNING: This will drop and recreate your local database from a Heroku dump."
    read -r -p "Continue? [y/N] " confirm
    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
      echo "Aborted."
      exit 0
    fi

    # Fetch the remote DATABASE_URL from Heroku.
    HEROKU_APP="${HEROKU_APP:-allocator-qa-backend}"
    echo "==> [db] Fetching DATABASE_URL from Heroku app: $HEROKU_APP"
    REMOTE_URL=$(heroku config:get DATABASE_URL --app "$HEROKU_APP")

    # Dump the remote database.
    DUMP_FILE="/tmp/allocator-qa_localize.dump"
    echo "==> [db] Dumping remote database …"
    pg_dump --format=custom "$REMOTE_URL" -f "$DUMP_FILE"

    # Drop and recreate the local database.
    DB_NAME="${DATABASE_URL##*/}"
    DB_NAME="${DB_NAME%%\?*}"
    echo "==> [db] Recreating local database: $DB_NAME"
    dropdb --if-exists "$DB_NAME"
    createdb "$DB_NAME"

    # Restore.
    echo "==> [db] Restoring dump …"
    pg_restore --no-owner --no-privileges -d "$DB_NAME" "$DUMP_FILE"
    rm -f "$DUMP_FILE"

    echo "==> [db] Localize complete."
    ;;

  *)
    echo "Usage: bin/db {migrate|seed|localize}" >&2
    exit 1
    ;;
esac
