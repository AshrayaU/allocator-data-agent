#!/usr/bin/env bash
set -euo pipefail

# ---------------------------------------------------------------------------
# backend/bin/logs
#
# Tails backend/.run/server.log with a [backend] prefix.
# ---------------------------------------------------------------------------

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BACKEND_DIR="$(dirname "$SCRIPT_DIR")"
LOG_FILE="$BACKEND_DIR/.run/server.log"

# Source .env on dev.
if [[ -f "$BACKEND_DIR/.env" ]]; then
  set -a
  # shellcheck disable=SC1091
  source "$BACKEND_DIR/.env"
  set +a
fi

# SERVER_TYPE is required.
if [[ -z "${SERVER_TYPE:-}" ]]; then
  echo "ERROR: SERVER_TYPE is not set. Set it to 'dev' or 'production' in .env." >&2
  exit 1
fi

if [[ ! -f "$LOG_FILE" ]]; then
  echo "No log file found at $LOG_FILE — has the server been started?" >&2
  exit 1
fi

# Tail with a cyan [backend] prefix.
tail -f "$LOG_FILE" | sed 's/^/\x1b[36m[backend]\x1b[0m /'
