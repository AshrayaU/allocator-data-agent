# Copy to .env. Never commit .env.

DATABASE_URL=
TEST_DATABASE_URL=

APP_SECRET=
SERVER_TYPE=dev
ALLOCATOR_API_BASE=https://secure.allocator.com/admin/api

LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

APP_BASE=backend

# Allocator Admin API (HTTP Basic auth). NOTE: the live Swagger docs and this
# skill's vendored template disagree on which is the username vs password —
# verify against GET /whoami once you have real values (see
# docs/ADMIN_API_NOTES.md); a 401 here likely means these two are swapped.
ALLOCATOR_ADMIN_SECRET_KEY=
ALLOCATOR_ADMIN_AUTH_TOKEN=

# Anthropic / Claude API
ANTHROPIC_API_KEY=
SUMMARY_MODEL=claude-sonnet-5