#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

# Load root .env if present (root should not normally have one — this is a safety valve)
if [[ -f "$ROOT_DIR/.env" ]]; then
  # shellcheck disable=SC1091
  set -a; source "$ROOT_DIR/.env"; set +a
fi

if [[ -z "${SERVER_TYPE:-}" ]]; then
  echo "ERROR: SERVER_TYPE is not set. Copy .env.example to .env in backend/ and frontend/ and set SERVER_TYPE=dev." >&2
  exit 1
fi

echo "==> Deploying backend..."
"$ROOT_DIR/backend/bin/deploy"

echo "==> Deploying frontend..."
"$ROOT_DIR/frontend/bin/deploy"

echo "==> All done. Run 'bin/server start' to start both halves."
